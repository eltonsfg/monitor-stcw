# Copia este ficheiro para .env e preenche os valores
# O ficheiro .env NUNCA deve ser enviado para o GitHub

# Email de envio (Gmail recomendado)
EMAIL_FROM=seuemail@gmail.com

# App Password do Gmail
# Como obter: Google Account → Segurança → Verificação em duas etapas → App Passwords
# Cria um app password para "Mail" e copia aqui (16 caracteres, sem espaços)
EMAIL_PASSWORD=abcdabcdabcdabcd

# Email de destino (pode ser o mesmo)
EMAIL_TO=seuemail@gmail.com

# SMTP (não precisas mudar se usas Gmail)
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587
